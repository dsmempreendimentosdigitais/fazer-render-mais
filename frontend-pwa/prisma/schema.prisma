generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Plano: FREE, PLUS, PREMIUM
  plan           String    @default("FREE")
  
  // Gamification
  wealthCoins    Int       @default(0)
  currentStreak  Int       @default(0)
  highestStreak  Int       @default(0)
  lastLoginDate  DateTime?
  score          Int       @default(0)

  // Perfil Financeiro
  objective      String?
  riskProfile    String?   // Conservador, Moderado, Arrojado
  monthlyAporte   Float?
  
  // Relacionamentos Gamificação / Progressão
  progress       UserProgress[]
  badges         UserBadge[]
  accounts       Account[]
  sessions       Session[]
  chatMessages   ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'user' ou 'ai'
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProgress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String   // Ex: '1.3', '0.1'
  trilhaId     String   // Ex: 'TRILHA_1', 'TRILHA_0'
  completedAt  DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String   // Ex: 'Semente_Plantada', 'Poupanca_Nunca_Mais'
  earnedAt  DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// NextAuth Models obrigatórios para provedores OAuth (Google, etc)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
